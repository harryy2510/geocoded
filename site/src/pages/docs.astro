---
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.geocoded.me'
const postmanUrl = `${apiUrl}/postman.json`
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>API Reference | Geocoded</title>
		<meta name="description" content="Interactive API reference for Geocoded. Full OpenAPI 3.1 documentation." />
		<meta name="theme-color" content="#0a0a0b" />
		<link rel="icon" type="image/svg+xml" href="/logo-background.svg" />
		<style>
			.dark-mode {
				color-scheme: dark;
				--scalar-color-1: rgba(255, 255, 245, .86);
				--scalar-color-2: rgba(255, 255, 245, .6);
				--scalar-color-3: rgba(255, 255, 245, .38);
				--scalar-color-disabled: rgba(255, 255, 245, .25);
				--scalar-color-ghost: rgba(255, 255, 245, .25);
				--scalar-color-accent: #3b82f6;
				--scalar-background-1: #0a0a0b;
				--scalar-background-2: #131316;
				--scalar-background-3: #1e1e24;
				--scalar-background-4: rgba(255, 255, 255, 0.06);
				--scalar-background-accent: #3b82f61f;
				--scalar-border-color: rgba(255, 255, 255, 0.1);
				--scalar-scrollbar-color: rgba(255, 255, 255, 0.24);
				--scalar-scrollbar-color-active: rgba(255, 255, 255, 0.48);
				--scalar-lifted-brightness: 1.45;
				--scalar-backdrop-brightness: 0.5;
				--scalar-shadow-1: 0 1px 3px 0 rgb(0, 0, 0, 0.1);
				--scalar-shadow-2: rgba(15, 15, 15, 0.2) 0px 3px 6px, rgba(15, 15, 15, 0.4) 0px 9px 24px, 0 0 0 1px rgba(255, 255, 255, 0.1);
				--scalar-button-1: #f6f6f6;
				--scalar-button-1-color: #000;
				--scalar-button-1-hover: #e7e7e7;
				--scalar-color-green: #3dd68c;
				--scalar-color-red: #f66f81;
				--scalar-color-yellow: #f9b44e;
				--scalar-color-blue: #5c73e7;
				--scalar-color-orange: #ff8d4d;
				--scalar-color-purple: #b191f9;
			}
			.dark-mode .sidebar {
				--scalar-sidebar-background-1: #0a0a0b;
				--scalar-sidebar-item-hover-color: var(--scalar-color-accent);
				--scalar-sidebar-item-hover-background: transparent;
				--scalar-sidebar-item-active-background: transparent;
				--scalar-sidebar-border-color: transparent;
				--scalar-sidebar-color-1: var(--scalar-color-1);
				--scalar-sidebar-color-2: var(--scalar-color-2);
				--scalar-sidebar-color-active: var(--scalar-color-accent);
				--scalar-sidebar-search-background: #131316;
				--scalar-sidebar-search-border-color: transparent;
				--scalar-sidebar-search-color: var(--scalar-color-3);
			}
			.geocoded-postman-link {
				align-items: center;
				gap: .625rem;
				justify-content: space-between;
			}
			.geocoded-postman-badge {
				background: var(--scalar-button-1);
				border-radius: 999px;
				color: var(--scalar-button-1-color);
				font-size: .75em;
				line-height: 1;
				padding: .35em .65em;
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<script
			id="api-reference"
			data-url={`${apiUrl}/openapi.json`}
			data-configuration={JSON.stringify({
				theme: 'saturn',
				darkMode: true,
				hideDarkModeToggle: true,
				defaultOpenAllTags: true,
			})}
		></script>
		<script src="https://cdn.jsdelivr.net/npm/@scalar/api-reference"></script>
		<script define:vars={{ postmanUrl }}>
			const isDownloadItem = (element) =>
				element.textContent?.includes('Download OpenAPI Document')

			const getDownloadMenu = (element) => {
				let current = element.parentElement
				while (current && current !== document.body) {
					const downloadItemCount = Array.from(
						current.querySelectorAll('a, button')
					).filter(isDownloadItem).length
					if (downloadItemCount >= 2) return current
					current = current.parentElement
				}
				return element.parentElement
			}

			const addPostmanLink = () => {
				const downloadItems = Array.from(
					document.querySelectorAll('a, button')
				).filter(isDownloadItem)

				for (const item of downloadItems) {
					const menu = getDownloadMenu(item)
					if (!menu || menu.querySelector('[data-geocoded-postman-link]')) {
						continue
					}

					const link = document.createElement('a')
					link.href = postmanUrl
					link.target = '_blank'
					link.rel = 'noreferrer'
					link.download = 'geocoded-postman-collection.json'
					link.className = `${item.className} geocoded-postman-link`.trim()
					link.setAttribute('data-geocoded-postman-link', 'true')

					const label = document.createElement('span')
					label.textContent = 'Download Postman Collection'

					const badge = document.createElement('span')
					badge.className = 'geocoded-postman-badge'
					badge.textContent = 'postman'

					link.replaceChildren(label, badge)
					menu.append(link)
				}
			}

			new MutationObserver(addPostmanLink).observe(document.body, {
				childList: true,
				subtree: true,
			})
			addPostmanLink()
		</script>
	</body>
</html>
