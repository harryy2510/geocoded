---
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.geocoded.me'
const openApiUrl = `${apiUrl}/openapi.json`
const postmanUrl = `${apiUrl}/postman.json`
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>API Reference | Geocoded</title>
		<meta name="description" content="Interactive API reference for Geocoded. Full OpenAPI 3.1 documentation." />
		<meta name="theme-color" content="#0a0a0b" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<style is:global>
			.dark-mode {
				color-scheme: dark;
				--scalar-color-1: rgba(255, 255, 245, .86);
				--scalar-color-2: rgba(255, 255, 245, .6);
				--scalar-color-3: rgba(255, 255, 245, .38);
				--scalar-color-disabled: rgba(255, 255, 245, .25);
				--scalar-color-ghost: rgba(255, 255, 245, .25);
				--scalar-color-accent: #22c55e;
				--scalar-background-1: #0a0a0b;
				--scalar-background-2: #131316;
				--scalar-background-3: #1e1e24;
				--scalar-background-4: rgba(255, 255, 255, 0.06);
				--scalar-background-accent: #22c55e1f;
				--scalar-border-color: rgba(255, 255, 255, 0.1);
				--scalar-scrollbar-color: rgba(255, 255, 255, 0.24);
				--scalar-scrollbar-color-active: rgba(255, 255, 255, 0.48);
				--scalar-lifted-brightness: 1.45;
				--scalar-backdrop-brightness: 0.5;
				--scalar-shadow-1: 0 1px 3px 0 rgb(0, 0, 0, 0.1);
				--scalar-shadow-2: rgba(15, 15, 15, 0.2) 0px 3px 6px, rgba(15, 15, 15, 0.4) 0px 9px 24px, 0 0 0 1px rgba(255, 255, 255, 0.1);
				--scalar-button-1: #f6f6f6;
				--scalar-button-1-color: #000;
				--scalar-button-1-hover: #e7e7e7;
				--scalar-color-green: #3dd68c;
				--scalar-color-red: #f66f81;
				--scalar-color-yellow: #f9b44e;
				--scalar-color-blue: #5c73e7;
				--scalar-color-orange: #ff8d4d;
				--scalar-color-purple: #b191f9;
			}
			.dark-mode .sidebar {
				--scalar-sidebar-background-1: #0a0a0b;
				--scalar-sidebar-item-hover-color: var(--scalar-color-accent);
				--scalar-sidebar-item-hover-background: transparent;
				--scalar-sidebar-item-active-background: transparent;
				--scalar-sidebar-border-color: transparent;
				--scalar-sidebar-color-1: var(--scalar-color-1);
				--scalar-sidebar-color-2: var(--scalar-color-2);
				--scalar-sidebar-color-active: var(--scalar-color-accent);
				--scalar-sidebar-search-background: #131316;
				--scalar-sidebar-search-border-color: transparent;
				--scalar-sidebar-search-color: var(--scalar-color-3);
			}
			.tag-section-container > .section:has(.endpoints-card) {
				display: none;
			}
			.geocoded-docs-links {
				align-items: center;
				display: flex;
				flex-wrap: wrap;
				gap: .625rem;
				margin-top: 1.25rem;
			}
			.geocoded-docs-link {
				align-items: center;
				background: #131316;
				border: 1px solid rgba(255, 255, 255, .16);
				border-radius: 999px;
				color: rgba(255, 255, 245, .86);
				display: inline-flex;
				gap: .625rem;
				font: 600 14px/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				padding: .75rem 1rem;
				text-decoration: none !important;
				text-decoration-line: none !important;
			}
			.markdown a.geocoded-docs-link,
			.markdown a.geocoded-docs-link:hover,
			.geocoded-docs-link {
				-webkit-text-fill-color: currentColor !important;
				color: currentColor !important;
				text-decoration: none !important;
				text-decoration-line: none !important;
			}
			.geocoded-docs-link > span:not(.geocoded-docs-badge) {
				-webkit-text-fill-color: currentColor !important;
				color: currentColor !important;
				text-decoration: none !important;
				text-decoration-line: none !important;
			}
			.geocoded-docs-link-primary,
			.geocoded-docs-link-secondary {
				background: #131316;
				border: 1px solid rgba(255, 255, 255, .16);
				color: rgba(255, 255, 245, .86);
			}
			.geocoded-docs-link-primary:hover,
			.geocoded-docs-link-secondary:hover {
				background: #1e1e24;
			}
			.geocoded-docs-badge {
				-webkit-text-fill-color: #0a0a0b !important;
				background: #f6f6f6;
				border-radius: 999px;
				color: #0a0a0b !important;
				font-size: .72em;
				line-height: 1;
				padding: .35em .65em;
				text-decoration: none !important;
				text-decoration-line: none !important;
			}
			@media (max-width: 720px) {
				.geocoded-docs-link {
					flex: 1;
					justify-content: center;
				}
			}
		</style>
	</head>
	<body class="dark-mode">
		<div data-open-api-url={openApiUrl} data-postman-url={postmanUrl}></div>
		<script is:inline>
			;(() => {
				const root = document.querySelector('[data-open-api-url]')
				const openApiUrl = root?.dataset.openApiUrl
				const postmanUrl = root?.dataset.postmanUrl

				if (!root || !openApiUrl || !postmanUrl) {
					return
				}

				const downloadActions = [
					{
						badge: 'json',
						className: 'geocoded-docs-link-primary',
						download: 'geocoded-openapi.json',
						href: openApiUrl,
						label: 'Download OpenAPI JSON'
					},
					{
						badge: 'postman',
						className: 'geocoded-docs-link-secondary',
						download: 'geocoded-postman-collection.json',
						href: postmanUrl,
						label: 'Download Postman Collection'
					}
				]

				function buildDocsLinks() {
					const container = document.createElement('nav')
					container.className = 'geocoded-docs-links'
					container.setAttribute('aria-label', 'Download API documents')

					for (const action of downloadActions) {
						const link = document.createElement('a')
						link.className = `geocoded-docs-link ${action.className}`
						link.href = action.href
						link.target = '_blank'
						link.rel = 'noreferrer'
						link.download = action.download

						const label = document.createElement('span')
						label.textContent = action.label

						const badge = document.createElement('span')
						badge.className = 'geocoded-docs-badge'
						badge.textContent = action.badge

						link.append(label, badge)
						container.append(link)
					}

					return container
				}

				function mountDocsLinks() {
					if (document.querySelector('.geocoded-docs-links')) {
						return true
					}

					const intro =
						document.querySelector('.introduction-section .markdown') ??
						document.querySelector('.introduction-section')

					if (!intro) {
						return false
					}

					const firstParagraph = intro.querySelector('p')
					const links = buildDocsLinks()

					if (firstParagraph) {
						firstParagraph.after(links)
						return true
					}

					intro.append(links)
					return true
				}

				function watchDocsLinks() {
					let attempts = 0
					const interval = window.setInterval(() => {
						attempts += 1

						if (mountDocsLinks() || attempts > 120) {
							window.clearInterval(interval)
						}
					}, 100)
				}

				window.mountGeocodedDocsReference = function mountGeocodedDocsReference() {
					if (!window.Scalar || root.dataset.scalarMounted === 'true') {
						return
					}

					root.dataset.scalarMounted = 'true'
					window.Scalar.createApiReference(root, {
						url: openApiUrl,
						theme: 'saturn',
						darkMode: true,
						hideDarkModeToggle: true,
						defaultOpenAllTags: true,
						documentDownloadType: 'none',
					})
					watchDocsLinks()
				}

				if (window.Scalar) {
					window.mountGeocodedDocsReference()
				}
			})()
		</script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/@scalar/api-reference" onload="window.mountGeocodedDocsReference()"></script>
	</body>
</html>
