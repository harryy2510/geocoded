---
import '../styles/global.css'

type Props = {
	title?: string
	description?: string
}

const {
	title = 'Geocoded - Global Geography Data Visualization',
	description = 'Explore 252 countries, 5000+ states, and 232K+ cities with interactive charts, maps, and quizzes. Powered by the Geocoded API.',
} = Astro.props

const currentPath = Astro.url.pathname

const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/dashboard', label: 'Dashboard' },
	{ href: '/explorer', label: 'Explorer' },
	{ href: '/statistics', label: 'Statistics' },
	{ href: '/quiz', label: 'Quiz' },
	{ href: '/docs', label: 'API Docs' },
]
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0a0b" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="flex min-h-dvh flex-col bg-bg text-text">
		<nav class="sticky top-0 z-50 border-b border-border/50 bg-bg/70 backdrop-blur-2xl">
			<!-- Subtle bottom glow -->
			<div class="absolute inset-x-0 -bottom-px h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
			<div class="absolute inset-x-0 -bottom-8 h-8 bg-gradient-to-b from-accent/[0.04] to-transparent pointer-events-none"></div>
			<div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3.5 sm:px-6">
				<a href="/" class="group flex items-center gap-2.5">
					<img src="/logo-background.svg" alt="Geocoded" class="size-8 rounded-lg transition-transform group-hover:scale-105" width="32" height="32" />
					<span class="text-lg font-bold tracking-tight">Geocoded</span>
				</a>
				<div class="hidden items-center gap-0.5 md:flex">
					{navLinks.map((link) => (
						<a
							href={link.href}
							class:list={[
								'rounded-lg px-3 py-1.5 text-sm font-medium transition-all',
								currentPath === link.href
									? 'bg-accent/15 text-accent shadow-[inset_0_1px_0_0_rgba(34,197,94,0.12)]'
									: 'text-text-muted hover:bg-white/[0.04] hover:text-text',
							]}
						>
							{link.label}
						</a>
					))}
				</div>
				<button
					id="mobile-menu-btn"
					class="flex size-9 items-center justify-center rounded-lg text-text-muted hover:bg-bg-card md:hidden"
					aria-label="Toggle menu"
				>
					<svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
			<div id="mobile-menu" class="hidden border-t border-border/50 md:hidden">
				<div class="flex flex-col gap-1 px-4 py-3">
					{navLinks.map((link) => (
						<a
							href={link.href}
							class:list={[
								'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
								currentPath === link.href
									? 'bg-accent/15 text-accent'
									: 'text-text-muted hover:bg-bg-card hover:text-text',
							]}
						>
							{link.label}
						</a>
					))}
				</div>
			</div>
		</nav>

		<main class="mx-auto max-w-7xl flex-1 px-4 py-8 sm:px-6">
			<slot />
		</main>

		<footer class="mt-auto border-t border-border/50 relative">
			<!-- Top gradient glow -->
			<div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
			<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
				<div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
					<div class="flex items-center gap-3">
						<img src="/logo-background.svg" alt="Geocoded" class="size-7 rounded-md" width="28" height="28" />
						<span class="text-sm font-semibold text-text-muted">Geocoded</span>
					</div>
					<div class="flex flex-wrap items-center justify-center gap-2 text-sm text-text-dim">
						<span>Data from</span>
						<a href="https://www.geonames.org/" class="text-text-muted transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">GeoNames</a>
						<span class="text-border">/</span>
						<a href="https://cldr.unicode.org/" class="text-text-muted transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">Unicode CLDR</a>
						<span class="text-border">/</span>
						<a href="https://www.iana.org/time-zones" class="text-text-muted transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">IANA</a>
						<span class="text-border">/</span>
						<a href="https://www.six-group.com/en/products-services/financial-information/data-standards.html" class="text-text-muted transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">ISO 4217</a>
						<span class="text-border">/</span>
						<a href="https://www.naturalearthdata.com/" class="text-text-muted transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">Natural Earth</a>
						<span class="text-border">/</span>
						<a href="https://www.cia.gov/the-world-factbook/" class="text-text-muted transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">CIA Factbook</a>
					</div>
					<div class="flex items-center gap-4 text-sm">
						<a
							href="https://creativecommons.org/licenses/by/4.0/"
							class="text-text-dim transition-colors hover:text-accent"
							target="_blank"
							rel="noopener noreferrer"
						>
							CC BY 4.0
						</a>
						<a
							href="/docs"
							class="text-text-dim transition-colors hover:text-accent"
						>
							Docs
						</a>
						<a
							href="https://github.com/harryy2510/geocoded"
							class="text-text-dim transition-colors hover:text-accent"
							target="_blank"
							rel="noopener noreferrer"
						>
							GitHub
						</a>
					</div>
				</div>
			</div>
		</footer>

		<script>
			const btn = document.getElementById('mobile-menu-btn')
			const menu = document.getElementById('mobile-menu')
			btn?.addEventListener('click', () => {
				menu?.classList.toggle('hidden')
			})
		</script>
	</body>
</html>
