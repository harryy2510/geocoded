{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"lib": ["ESNext"],
		"types": ["node", "bun"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true
	},
	"include": [
		"src/**/*.ts",
		"scripts/**/*.ts",
		"tests/**/*.ts",
		"worker-configuration.d.ts"
	]
}
