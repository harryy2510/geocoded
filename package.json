{
	"name": "geo-api",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"seed": "bun scripts/seed.ts",
		"seed:upload": "bun scripts/seed.ts --upload",
		"types": "wrangler types",
		"check": "bun lint:check && bun format:check",
		"fix": "bun lint:fix && bun format:fix",
		"lint:check": "oxlint --type-aware --type-check --max-warnings 0",
		"lint:fix": "oxlint --type-aware --type-check --fix",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt"
	},
	"dependencies": {
		"hono": "^4.12.15"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"@types/node": "^25.6.0",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.0",
		"wrangler": "^4.86.0"
	}
}
